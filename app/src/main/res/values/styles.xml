<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VibrationApp" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/brand_green_dark</item>
        <item name="colorAccent">@color/brand_amber</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- typography presets -->
    <style name="Text.Display" parent="">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Text.Heading" parent="">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Body" parent="">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Text.Label" parent="">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- stat card -->
    <style name="Card.Stat" parent="">
        <item name="android:background">@drawable/bg_stat_card</item>
        <item name="android:padding">@dimen/space_lg</item>
        <item name="android:layout_marginTop">@dimen/space_md</item>
        <item name="android:layout_marginStart">@dimen/space_md</item>
        <item name="android:layout_marginEnd">@dimen/space_md</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- buttons -->
    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="backgroundTint">@color/brand_green</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/brand_green_dark</item>
    </style>

    <style name="Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="backgroundTint">@color/bg_surface_raised</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="elevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/text_tertiary</item>
    </style>
</resources>